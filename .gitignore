# 凭证 / 密钥
.env
.env.*
!.env.example
*.key
*.pem

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 虚拟环境
venv/
.venv/
env/

# 数据快照（运行时生成）
# 注: 用 data/* 而不是 data/, 是为了让下面的 !data/curated/ negation 能生效
# (git 不允许 re-include 父目录已被 exclude 的子文件, 必须父目录用 glob 排除)
data/*
# 例外：data/curated/ 是手维护的源数据（不是 generated），必须入库
!data/curated/
!data/curated/**
prices_*.json
review_*.json
13f_snapshots/
# stock_history.duckdb 入库做事实来源；只忽略 WAL 与临时备份
*.duckdb.wal
*.duckdb.tmp

# 根目录 cache（daily_picks_v5 每天重写，不该入库）
factor_scores_today.json

# 日志
*.log
daily_refresh.log*

# 派生产物 — daily_refresh 每天重建，diff 噪音大
stock_dashboard.html
morning_brief.md

# 2026-05-21 DuckDB 出仓：74MB 超 GitHub 50MB 推荐上限。
# 用户状态（holdings/manual_watchlist/portfolio_plans/recommendation_runs/picks/pick_outcomes）
# 改由 scripts/tools/backup_state_to_json.py 落 state_backup/*.json，是 source of truth。
# 重建流程：python3 scripts/tools/init_stock_db_v2.py --reset --seed-universe
#         + python3 scripts/tools/restore_state_from_json.py
*.duckdb

# 编辑器
.idea/
.vscode/
*.swp
.DS_Store

# 飞书开发者工具临时文件
.feishu/

# 2026-05-11 Phase 5 整理
.env.bak
logs/

# Claude / 调度器锁文件（运行时生成）
.claude/scheduled_tasks.lock
.claude/*.lock
