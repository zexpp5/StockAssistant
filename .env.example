# ─────────── 飞书自建应用（必填）───────────
# 在 https://open.feishu.cn 创建自建应用，"凭证与基础信息"页能拿到
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 多维表 base 的 app_token（从表格 URL 里取：base/<app_token>?table=...）
FEISHU_APP_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# stock_research 包额外用的 base token（与 FEISHU_APP_TOKEN 相同即可）
FEISHU_BASE_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# 飞书表 ID（在表格 URL 里取 ?table=tbl... 之后的部分）
FEISHU_WATCHLIST_TABLE_ID=tblxxxxxxxxxx
FEISHU_PICKS_TABLE_ID=tblxxxxxxxxxx
FEISHU_EVENTS_TABLE_ID=tblxxxxxxxxxx
FEISHU_PEERS_TABLE_ID=tblxxxxxxxxxx

# ─────────── Finnhub（可选，启用后多 80% 美股数据维度）───────────
# 免费注册：https://finnhub.io/register
FINNHUB_API_KEY=

# ─────────── SEC EDGAR（合规要求带联系方式）───────────
# SEC 要求所有 API 请求带 User-Agent，包含真实联系方式
SEC_USER_AGENT=your-name your-email@example.com

# ─────────── 部署路径（可选）───────────
# 部署到非默认位置时设置；不设置则用脚本所在目录
# STOCK_RESEARCH_BASE=/opt/stock_assistant
